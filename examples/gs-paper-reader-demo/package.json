{
  "name": "@gs/paper-reader-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "End-to-end demo app for @gs/paper-reader workflows on top of PDF.js.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.demo.json && vite build",
    "typecheck": "tsc -p tsconfig.demo.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gs/paper-reader": "file:../../packages/gs-paper-reader",
    "pdfjs-dist": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "license": "Apache-2.0"
}
